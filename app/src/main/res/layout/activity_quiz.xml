<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0CE91E63">

    <ProgressBar
        android:id="@+id/quizProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progress="30"
        android:max="100"
        android:progressTint="#8BC34A"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvQuestionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Soru: 3 / 10"
        android:textColor="#666666"
        android:layout_gravity="end"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivQuestionImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_marginBottom="16dp"
                android:visibility="visible"/>

            <TextView
                android:id="@+id/tvQuestionWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apple"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1507D7"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnOption1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Armut"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#2D3436"
        app:strokeColor="#D1D1D1"
        app:strokeWidth="1dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <Button
        android:id="@+id/btnOption2"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Elma"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#2D3436"
        app:strokeColor="#D1D1D1"
        app:strokeWidth="1dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <Button
        android:id="@+id/btnOption3"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Muz"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#2D3436"
        app:strokeColor="#D1D1D1"
        app:strokeWidth="1dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <Button
        android:id="@+id/btnOption4"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Kivi"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#2D3436"
        app:strokeColor="#D1D1D1"
        app:strokeWidth="1dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

</LinearLayout>