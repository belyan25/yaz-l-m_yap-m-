            <TextView android:id="@+id/tv5" android:layout_width="55dp" android:layout_height="55dp" android:layout_margin="3dp" android:background="@drawable/box_style" android:gravity="center" android:textSize="22sp" android:textStyle="bold" android:textColor="#333333"/>

            <TextView android:id="@+id/tv6" android:layout_width="55dp" android:layout_height="55dp" android:layout_margin="3dp" android:background="@drawable/box_style" android:gravity="center" android:textSize="22sp" android:textStyle="bold" android:textColor="#333333"/>
