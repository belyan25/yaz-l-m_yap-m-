<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Word Chain"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#353434"
            android:layout_marginBottom="8dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hikayede geçmesini istediğin 5 kelimeyi gir:"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/etWord1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="1. Kelime"
            android:inputType="text"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="15dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWord2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="2. Kelime"
            android:inputType="text"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="15dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWord3"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="3. Kelime"
            android:inputType="text"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="15dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWord4"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="4. Kelime"
            android:inputType="text"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="15dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWord5"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="5. Kelime"
            android:inputType="text"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="15dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGenerateStory"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="HADİ HİKAYE OLUŞTURALIM :)"
            android:backgroundTint="#353434"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvAiStory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yapay zeka hikayeyi burada oluşturacak..."
            android:textSize="16sp"
            android:textColor="#333333"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="20dp"
            android:padding="16dp"
            android:background="#EEEEEE"/>

        <ImageView
            android:id="@+id/ivAiImage"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="20dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"/>

    </LinearLayout>
</ScrollView>