<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D353434">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvWordsChain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zincir Kelimeler: ..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnGenerateStory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HADİ HİKAYE OLUŞTURALIM :)"
            android:backgroundTint="#353434"
            android:textColor="@android:color/white"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvAiStory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hikaye burada belirecek..."
            android:textSize="16sp"
            android:textColor="#555555"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="20dp"
            android:padding="8dp"
            android:background="#EEEEEE"/>

        <ImageView
            android:id="@+id/ivAiImage"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"/>

    </LinearLayout>
</ScrollView>